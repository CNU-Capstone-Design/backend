FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-another-random-secret
AES_KEY=0123456789abcdef0123456789abcdef
DATABASE_URL=sqlite:///face_sim.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
# CORS 허용 Origin (쉼표로 여러 개 구분 가능)
# start.sh 를 쓸 경우 루트 .env 의 CORS_ORIGINS 가 환경변수로 자동 주입됩니다.
# 직접 실행 시에는 아래 값이 사용됩니다.
CORS_ORIGINS=http://localhost:5173

# ── 인퍼런스 서버 설정 ──────────────────────────────────
# 홈 서버 Tailscale IP 로 직접 접근 (컴퓨터가 켜져 있을 때만 동작)
INFERENCE_SERVER_URL=http://100.118.230.17:7860
# 인퍼런스 서버의 X-API-Key 헤더 값 (inference_server/.env 와 동일하게 설정)
INFERENCE_API_KEY=your-secret-key-here
# 인퍼런스 타임아웃 (초, 기본 120)
INFERENCE_TIMEOUT_SEC=120
